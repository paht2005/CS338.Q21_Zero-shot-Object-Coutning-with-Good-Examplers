\begin{block}{\textbf{Thành phần chính}}
\begin{itemize}
  \item \texttt{demo\_app\_advanced.py}: ứng dụng Streamlit nâng cao.
  \item \texttt{demo\_inference.py}: thư viện suy luận dùng chung.
  \item \texttt{demo\_pipeline\_advanced.py}: module pipeline đầy đủ.
  \item \texttt{demo\_visualization.py}: các hàm vẽ overlay.
\end{itemize}
\end{block}

\setbeamercolor{block title}{bg=teal!70!black, fg=white}
\setbeamercolor{block body}{bg=teal!5!white}
