\begin{column}{0.45\textwidth}

\setbeamercolor{block title}{bg=green!70!black, fg=white}
\setbeamercolor{block body}{bg=green!5!white}
\begin{block}{\textbf{Hướng dẫn cài đặt}}
\begin{lstlisting}[style=codestyle, language=bash, numbers=none]
cd code/source-code
python -m venv .venv
source .venv/bin/activate
pip install -r requirements.txt

# Set Gemini API key
cp .env.example .env
# edit .env: GEMINI_API_KEY=...

# Run Streamlit demo
streamlit run demo_app_advanced.py
\end{lstlisting}
\end{block}

\end{column}
\end{columns}

