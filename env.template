# ============================================================
# Environment Template — CS338.Q21 Zero-shot Object Counting
# ============================================================
# Copy this file to `.env` in the project root (or code/source-code/.env)
# and fill in the values below. `.env` is gitignored and must NEVER be
# committed to version control.
# ============================================================

# ------ Google Gemini (Rich Prompt generation) ------
# Required for prompt_enhancer.py and the Streamlit demo when Rich Prompt
# mode is enabled. Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the default Gemini model used for prompt enhancement.
# GEMINI_MODEL_NAME=gemini-2.0-flash-exp

# ------ Weights & Biases (experiment tracking) ------
# Optional: set your wandb API key for automatic logging during training.
# WANDB_API_KEY=your-wandb-api-key-here
# WANDB_PROJECT=cs338-vacount

# ------ CUDA (GPU settings) ------
# Optional: restrict which GPU(s) are visible to PyTorch.
# CUDA_VISIBLE_DEVICES=0
